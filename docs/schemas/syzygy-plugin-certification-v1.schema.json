{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://syzygy.penumbra.invalid/schemas/plugin-certification-v1.schema.json",
  "title": "Syzygy Research Plugin Certification Plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "documentation",
    "license",
    "determinism",
    "fixtures",
    "authorityProbes"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "documentation": { "type": "string", "minLength": 1, "maxLength": 300 },
    "license": { "type": "string", "minLength": 1, "maxLength": 300 },
    "determinism": { "enum": ["deterministic", "stochastic"] },
    "fixtures": {
      "type": "array",
      "minItems": 2,
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "proposal", "expectedValid"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "proposal": { "type": "string", "minLength": 1, "maxLength": 300 },
          "expectedValid": { "type": "boolean" }
        }
      }
    },
    "authorityProbes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "capability", "expected"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "capability": {
            "enum": [
              "project.read",
              "project.propose",
              "drive.read",
              "drive.propose",
              "network.fetch",
              "model.invoke"
            ]
          },
          "target": { "type": "string", "minLength": 1, "maxLength": 500 },
          "expected": { "enum": ["allow", "deny"] }
        }
      }
    }
  }
}
