{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://syzygy.penumbra.invalid/schemas/provider-run-v1.schema.json",
  "title": "Syzygy Provider Run Record v1",
  "description": "Content-free provenance for one model invocation. Passing this structural schema does not prove disclosure, retention, endpoint, accounting, or runtime behavior; use the semantic validator too.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recordVersion",
    "runId",
    "callId",
    "provider",
    "request",
    "disclosure",
    "dataHandling",
    "result",
    "usage"
  ],
  "properties": {
    "recordVersion": { "const": 1 },
    "runId": { "$ref": "#/$defs/id" },
    "callId": { "$ref": "#/$defs/id" },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "transport", "model", "adapterStatus", "remote"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$" },
        "transport": {
          "enum": [
            "local-openai-compatible",
            "openai-responses",
            "anthropic-messages",
            "gemini-interactions",
            "xai-responses",
            "custom"
          ]
        },
        "model": { "type": "string", "minLength": 1, "maxLength": 200, "pattern": "\\S" },
        "adapterStatus": {
          "enum": [
            "available",
            "contract-only",
            "request-control-conformance",
            "request-and-stream-control-conformance",
            "live-verified"
          ]
        },
        "remote": { "type": "boolean" }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "taskType",
        "startedAt",
        "completedAt",
        "sourceSnapshotIds",
        "inputSha256",
        "maxOutputTokens",
        "timeoutMs",
        "stream"
      ],
      "properties": {
        "taskType": { "type": "string", "pattern": "^[a-z][a-z0-9.-]{1,127}$" },
        "startedAt": { "$ref": "#/$defs/timestamp" },
        "completedAt": { "$ref": "#/$defs/timestamp" },
        "sourceSnapshotIds": {
          "type": "array",
          "maxItems": 10000,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "inputSha256": { "$ref": "#/$defs/sha256" },
        "maxOutputTokens": { "type": "integer", "minimum": 1, "maximum": 10000000 },
        "timeoutMs": { "type": "integer", "minimum": 1, "maximum": 86400000 },
        "stream": { "type": "boolean" }
      }
    },
    "disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "approved", "approvedAt", "destination", "policyUrl", "policyCheckedAt"],
      "properties": {
        "required": { "type": "boolean" },
        "approved": { "type": "boolean" },
        "approvedAt": {
          "anyOf": [{ "$ref": "#/$defs/timestamp" }, { "type": "null" }]
        },
        "destination": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "policyUrl": {
          "anyOf": [{ "type": "string", "pattern": "^https://", "maxLength": 2048 }, { "type": "null" }]
        },
        "policyCheckedAt": {
          "anyOf": [{ "$ref": "#/$defs/timestamp" }, { "type": "null" }]
        }
      }
    },
    "dataHandling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["storageRequest", "zeroRetention", "attestation"],
      "properties": {
        "storageRequest": { "enum": ["local-only", "disabled", "provider-controlled"] },
        "zeroRetention": { "enum": ["not-applicable", "requested", "attested", "not-attested", "unknown"] },
        "attestation": {
          "anyOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "name", "value"],
              "properties": {
                "kind": { "enum": ["response-header", "provider-contract", "local-execution"] },
                "name": { "type": "string", "minLength": 1, "maxLength": 200 },
                "value": { "type": "boolean" }
              }
            },
            { "type": "null" }
          ]
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "outputSha256", "errorCode"],
      "properties": {
        "status": { "enum": ["completed", "failed", "cancelled", "timeout"] },
        "outputSha256": {
          "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
        },
        "errorCode": {
          "anyOf": [
            { "type": "string", "pattern": "^[a-z][a-z0-9.-]{1,127}$" },
            { "type": "null" }
          ]
        }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputTokens", "outputTokens", "totalTokens", "costUsd"],
      "properties": {
        "inputTokens": { "$ref": "#/$defs/nullableCount" },
        "outputTokens": { "$ref": "#/$defs/nullableCount" },
        "totalTokens": { "$ref": "#/$defs/nullableCount" },
        "costUsd": {
          "anyOf": [
            { "type": "number", "minimum": 0, "maximum": 1000000000 },
            { "type": "null" }
          ]
        }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "minLength": 1, "maxLength": 200, "pattern": "\\S" },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$"
    },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "nullableCount": {
      "anyOf": [
        { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        { "type": "null" }
      ]
    }
  }
}
