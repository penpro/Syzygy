{
  "name": "syzygy",
  "private": true,
  "version": "0.1.10",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test:watchdog": "node --test ../scripts/run-with-heartbeat.test.mjs",
    "fetch-engine": "node ../scripts/fetch-engine.mjs",
    "test": "vitest run",
    "test:workspace": "vitest run src/workspace src/migrations.test.ts --reporter=verbose",
    "test:contracts": "vitest run src/extensions --reporter=verbose",
    "test:adversarial": "vitest run src/extensions/adversarialProtocol.test.ts src/extensions/adversarialRunRecord.test.ts src/extensions/adversarialRunner.test.ts --reporter=verbose",
    "test:plugin-sdk": "node --test ../scripts/plugin-certifier.test.mjs",
    "test:plugin-host": "vitest run src/extensions/pluginAuthorityBroker.test.ts --reporter=verbose",
    "certify:plugin": "node ../scripts/plugin-certifier.mjs",
    "test:model-adapter-sdk": "node --test ../scripts/model-adapter-certifier.test.mjs",
    "certify:model-adapter": "node ../scripts/model-adapter-certifier.mjs",
    "test:providers": "cargo test --manifest-path src-tauri/Cargo.toml model_provider::tests:: -- --nocapture",
    "test:provider-runtime": "cargo test --manifest-path src-tauri/Cargo.toml provider_runtime::tests:: -- --nocapture",
    "test:provider-runtime-interop": "node ../scripts/provider-runtime-interop.mjs",
    "test:provider-streams": "cargo test --manifest-path src-tauri/Cargo.toml provider_stream::tests:: -- --nocapture",
    "test:credentials": "cargo test --manifest-path src-tauri/Cargo.toml credential_vault::tests:: -- --nocapture",
    "test:credentials:live": "cargo run --manifest-path src-tauri/Cargo.toml --bin credential-harness",
    "test:mcp": "node ../scripts/mcp-harness.mjs",
    "test:mcp:live": "node ../scripts/mcp-live-harness.mjs --write-proof",
    "audit": "node ../scripts/audit.mjs",
    "test:drive-live": "cargo run --manifest-path src-tauri/Cargo.toml --bin drive-harness --",
    "test:drive-write-live": "cargo run --manifest-path src-tauri/Cargo.toml --bin drive-write-harness --",
    "bump": "node ../scripts/bump.mjs"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "@lexical/react": "0.47.0",
    "@lexical/rich-text": "0.47.0",
    "@lexical/selection": "0.47.0",
    "@lexical/yjs": "0.47.0",
    "@sentry/react": "^10.63.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tauri-apps/plugin-upload": "^2.4.0",
    "highlight.js": "^11.10.0",
    "lexical": "0.47.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "y-indexeddb": "9.0.12",
    "y-protocols": "1.0.7",
    "yjs": "13.6.31",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "5.2.0",
    "ajv": "8.20.0",
    "fake-indexeddb": "6.2.5",
    "typescript": "^5.5.4",
    "vite": "7.3.6",
    "vitest": "^4.1.9"
  }
}
