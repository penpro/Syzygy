{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://syzygy.penumbra.invalid/schemas/plugin-proposal-v1.schema.json",
  "title": "Syzygy Plugin Change Proposal v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proposalVersion",
    "proposalId",
    "pluginId",
    "projectId",
    "expectedRevision",
    "summary",
    "content",
    "operation"
  ],
  "properties": {
    "proposalVersion": { "const": 1 },
    "proposalId": { "type": "string", "minLength": 1, "maxLength": 120 },
    "pluginId": { "type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$" },
    "projectId": { "type": "string", "minLength": 1, "maxLength": 200 },
    "expectedRevision": { "type": "string", "minLength": 1, "maxLength": 500 },
    "summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "content": { "type": "string", "minLength": 1, "maxLength": 200000 },
    "operation": { "enum": ["append", "replace"] }
  }
}
