{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Syzygy",
  "mainBinaryName": "Syzygy",
  "version": "0.1.4",
  "identifier": "com.penumbra.syzygy",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Syzygy",
        "decorations": false,
        "width": 1400,
        "height": 900,
        "minWidth": 940,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: http://asset.localhost https://asset.localhost; media-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:11435 http://localhost:11435",
      "assetProtocol": {
        "enable": false,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": ["nsis"],
    "resources": {
      "bin/llama/": "llama/",
      "bin/typst/": "typst/"
    },
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "languages": ["English"],
        "customLanguageFiles": {
          "English": "installer/English.nsh"
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/penpro/Syzygy/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY2NDFBMDlBRjJGMzZFRQpSV1R1TmkrdkNScGtCdDZkdlR2QmthZm1VZjdMdnhvL0dPaXZWQkpPRk1hckR6d0dVUFo0bG5aRQo=",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
