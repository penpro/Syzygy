{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://syzygy.penumbra.invalid/schemas/research-plugin-v1.schema.json",
  "title": "Syzygy Research Plugin Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "description",
    "runtime",
    "permissions",
    "contributions"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$",
      "description": "Stable dotted lowercase plugin identifier."
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
    },
    "description": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "runtime": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "component", "world"],
          "properties": {
            "kind": { "const": "wasi-component" },
            "component": { "type": "string", "minLength": 1 },
            "world": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "command", "args"],
          "properties": {
            "kind": { "const": "mcp-stdio" },
            "command": { "type": "string", "minLength": 1 },
            "args": { "type": "array", "items": { "type": "string" }, "maxItems": 64 }
          }
        }
      ]
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capabilities", "networkDomains", "modelProviders"],
      "properties": {
        "capabilities": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "project.read",
              "project.propose",
              "drive.read",
              "drive.propose",
              "network.fetch",
              "model.invoke"
            ]
          }
        },
        "networkDomains": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^(?:\\*\\.)?[A-Za-z0-9.-]+$" }
        },
        "modelProviders": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$" }
        }
      }
    },
    "contributions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "id", "title", "description"],
        "properties": {
          "kind": { "enum": ["tool", "evaluator", "importer", "exporter"] },
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "title": { "type": "string", "minLength": 1, "maxLength": 120 },
          "description": { "type": "string", "minLength": 1, "maxLength": 1000 }
        }
      }
    }
  }
}
